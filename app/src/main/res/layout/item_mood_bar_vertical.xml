<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="65dp"
    android:layout_height="220dp"
    android:layout_margin="8dp">

    <View
        android:id="@+id/viewOutline"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/mood_bar_outline" />

    <View
        android:id="@+id/viewMoodFill"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_margin="2dp"
        android:background="@drawable/mood_bar_pink_fill"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/imgMoodChar"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_marginTop="8dp"
        android:src="@drawable/moji_neutral"
        app:layout_constraintEnd_toEndOf="@id/viewMoodFill"
        app:layout_constraintStart_toStartOf="@id/viewMoodFill"
        app:layout_constraintTop_toTopOf="@id/viewMoodFill" />

</androidx.constraintlayout.widget.ConstraintLayout>