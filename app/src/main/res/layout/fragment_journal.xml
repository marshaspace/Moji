<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/journalRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/milkwhite_base">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_arrow_back"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Back"
        android:padding="12dp"
        android:layout_marginTop="24dp"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvWriteTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Write it Out"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:layout_marginStart="20dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Card journal utama -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardJournal"
        android:layout_width="0dp"
        android:layout_height="350dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvWriteTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <EditText
                android:id="@+id/etJournal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="What's on your mind today?"
                android:textSize="15sp"
                android:textColor="#1A1A1A"
                android:textColorHint="#AAAAAA"
                android:background="@null"
                android:padding="20dp"
                android:gravity="top"
                android:inputType="textMultiLine"/>

            <!-- Drawing overlay untuk scribble -->
            <com.moji.v1.ui.journal.DrawingView
                android:id="@+id/drawingView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"/>

            <!-- Photo yang dipilih -->
            <ImageView
                android:id="@+id/imgPhoto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone"/>

        </FrameLayout>

    </androidx.cardview.widget.CardView>

    <!-- Toolbar color + brush (muncul saat scribble mode) -->
    <LinearLayout
        android:id="@+id/toolbarScribble"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:visibility="gone"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/cardJournal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Color"
            android:textSize="12sp"
            android:textColor="#888888"
            android:layout_marginEnd="8dp"/>

        <View android:id="@+id/colorRed"
            android:layout_width="28dp" android:layout_height="28dp"
            android:background="#EF5350" android:layout_margin="4dp"/>
        <View android:id="@+id/colorYellow"
            android:layout_width="28dp" android:layout_height="28dp"
            android:background="#FFD527" android:layout_margin="4dp"/>
        <View android:id="@+id/colorGreen"
            android:layout_width="28dp" android:layout_height="28dp"
            android:background="#66BB6A" android:layout_margin="4dp"/>
        <View android:id="@+id/colorBlue"
            android:layout_width="28dp" android:layout_height="28dp"
            android:background="#5C85F5" android:layout_margin="4dp"/>
        <View android:id="@+id/colorPink"
            android:layout_width="28dp" android:layout_height="28dp"
            android:background="#F48FB1" android:layout_margin="4dp"/>

        <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Brush"
            android:textSize="12sp"
            android:textColor="#888888"
            android:layout_marginEnd="8dp"/>

        <ImageButton android:id="@+id/brushSmall"
            android:layout_width="32dp" android:layout_height="32dp"
            android:src="@drawable/ic_pencil"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Small brush"/>
        <ImageButton android:id="@+id/brushMedium"
            android:layout_width="32dp" android:layout_height="32dp"
            android:src="@drawable/ic_pencil"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Medium brush"/>
        <ImageButton android:id="@+id/brushLarge"
            android:layout_width="32dp" android:layout_height="32dp"
            android:src="@drawable/ic_pencil"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Large brush"/>

        <ImageButton
            android:id="@+id/btnUndo"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Undo"
            android:layout_marginStart="8dp"/>

        <ImageButton
            android:id="@+id/btnClearScribble"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_archive"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Clear"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <!-- Bottom action buttons -->
    <LinearLayout
        android:id="@+id/layoutActions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarScribble"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddPhoto"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:minHeight="48dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="Add photo"
            android:textSize="12sp"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_home"
            app:iconSize="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddSticker"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:minHeight="48dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="Add Sticker"
            android:textSize="12sp"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_pencil"
            app:iconSize="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddScribble"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:minHeight="48dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="Add Scribble"
            android:textSize="12sp"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_pencil"
            app:iconSize="16dp"/>

    </LinearLayout>

    <ImageView
        android:id="@+id/imgMoodBg"
        android:layout_width="350dp"
        android:layout_height="350dp"
        android:adjustViewBounds="true"
        android:alpha="0.9"
        android:contentDescription="Mood character"
        android:scaleType="fitCenter"
        android:layout_marginBottom="-150dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSave"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="Save Note"
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        app:cornerRadius="12dp"
        app:backgroundTint="#3D7EF5"
        app:layout_constraintTop_toBottomOf="@id/layoutActions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>